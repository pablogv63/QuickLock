<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.pablogv63.quicklock">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:name=".MainActivity"
            android:label="QuickLock">
            <!--android:theme="@style/AppTheme.NoActionBar"-->
            <intent-filter>
                <!--Establecemos la MainActivity como la Activity de inicio-->
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!--HAY QUE DECLARAR AQUÍ TODAS LAS ACTIVIDADES Y ESTABLECER SI PARTEN DE OTRA-->

        <!--BiometricActivity-->
        <activity
            android:name=".BiometricActivity"
            android:label="@string/title_activity_biometric"
            android:parentActivityName=".MainActivity">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value=".MainActivity"/>
        </activity>
        <!--/BiometricActivity-->


    </application>

</manifest>